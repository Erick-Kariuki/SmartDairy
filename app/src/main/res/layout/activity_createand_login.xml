<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CreateandLogin"
    android:gravity="center"
    android:background="@drawable/cow_image"
    android:orientation="vertical">

    <EditText
        android:id="@+id/txtFarmName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:hint="Please enter the name of your farm"
        android:textColor="@color/black"
        android:padding="7dp"
        android:layout_margin="10dp"
        android:textColorHint="#464646"
        android:textSize="24sp"/>

    <EditText
        android:id="@+id/txtFarmPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:hint="Please Enter Your Farm Password"
        android:textColorHint="#464646"
        android:inputType="textPassword"
        android:padding="7dp"
        android:layout_margin="10dp"
        android:textColor="@color/black"
        android:textSize="24sp"/>

    <Button
        android:id="@+id/CreateButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CREATE FARM"
        android:textStyle="bold"
        android:textSize="20sp"
        android:layout_margin="5dp"
        android:backgroundTint="#15A21A"/>

    <Button
        android:id="@+id/LoginButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOGIN TO FARM"
        android:textStyle="bold"
        android:textSize="20sp"
        android:layout_margin="5dp"
        android:backgroundTint="#15A21A"/>

</LinearLayout>